# Connector credentials
C2F_WINRM_USERNAME=
C2F_WINRM_PASSWORD=
C2F_WINRM_USERNAME_001=
C2F_WINRM_PASSWORD_001=
C2F_WINRM_USERNAME_004=
C2F_WINRM_PASSWORD_004=
C2F_SSH_USERNAME=
C2F_SSH_PASSWORD=
OTX_API_KEY=

# Wazuh / indexer (passed to backend container)
WAZUH_URL=https://WAZUH_MANAGER_IP:55000
WAZUH_USER=c2f_api
WAZUH_PASSWORD=REPLACE_WITH_WAZUH_PASSWORD
INDEXER_URL=https://WAZUH_INDEXER_IP:9200
INDEXER_USER=admin
INDEXER_PASSWORD=REPLACE_WITH_INDEXER_PASSWORD

# JWT
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_32_PLUS_CHARS

# Resource governance profiles
DB_CPU_RESERVATION=0.25
DB_CPU_LIMIT=1.00
DB_MEMORY_RESERVATION=256M
DB_MEMORY_LIMIT=1024M

BACKEND_CPU_RESERVATION=1.00
BACKEND_CPU_LIMIT=2.00
BACKEND_MEMORY_RESERVATION=1024M
BACKEND_MEMORY_LIMIT=2048M
BACKEND_MEMORY_LIMIT_MB=2048

FRONTEND_CPU_RESERVATION=0.25
FRONTEND_CPU_LIMIT=1.00
FRONTEND_MEMORY_RESERVATION=256M
FRONTEND_MEMORY_LIMIT=512M

# Circuit breaker defaults
C2F_CIRCUIT_BREAKER_ENABLED=true
C2F_CIRCUIT_BREAKER_THRESHOLD_PERCENT=90
C2F_CIRCUIT_BREAKER_POLL_SECONDS=2
C2F_CIRCUIT_BREAKER_MAX_PAUSE_SECONDS=120

C2F_WINDOWS_CONNECTOR_ENABLED=true
C2F_LINUX_CONNECTOR_ENABLED=false

# Appliance identity / branding (UI product name can be changed later without code changes)
APP_BRAND=Click2Fix

# Image sources
# For quick cross-system test without registry, build local images and set C2F_SKIP_PULL=true.
# For production, replace with your private registry names and tag.
C2F_BACKEND_IMAGE=click2fix-backend
C2F_FRONTEND_IMAGE=click2fix-frontend
C2F_IMAGE_TAG=local
C2F_SKIP_PULL=false
POSTGRES_IMAGE_TAG=16

# Service ports
C2F_FRONTEND_PORT=5173
C2F_BACKEND_PORT=8000
C2F_DB_PORT=5432

# Database
POSTGRES_DB=click2fix
POSTGRES_USER=click2fix
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Security
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
C2F_ALLOW_DEMO_USERS=false
C2F_BOOTSTRAP_ADMIN_USERNAME=admin
C2F_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
C2F_BOOTSTRAP_ADMIN_FORCE_RESET=false

# Network exposure policy (first-boot script will update these)
C2F_PUBLIC_HOST=
C2F_TRUSTED_HOSTS=localhost,127.0.0.1,*.localhost,backend,frontend,c2f-backend,c2f-frontend
C2F_CORS_ORIGINS=http://localhost:5173

# Wazuh Manager API
WAZUH_URL=https://WAZUH_MANAGER_IP:55000
WAZUH_USER=c2f_api
WAZUH_PASSWORD=CHANGE_ME_WAZUH_PASSWORD

# Wazuh Indexer
INDEXER_URL=https://WAZUH_INDEXER_IP:9200
INDEXER_USER=admin
INDEXER_PASSWORD=CHANGE_ME_INDEXER_PASSWORD
OTX_API_KEY=

# Endpoint connectors
C2F_WINDOWS_CONNECTOR_ENABLED=true
C2F_WINRM_USERNAME=DOMAIN\svc_click2fix
C2F_WINRM_PASSWORD=CHANGE_ME_WINRM_PASSWORD
C2F_LINUX_CONNECTOR_ENABLED=false
C2F_SSH_USERNAME=
C2F_SSH_PASSWORD=

# Resource profile (50-agent baseline; tune as needed)
DB_CPU_LIMIT=1.00
DB_MEMORY_RESERVATION=256M
DB_MEMORY_LIMIT=1024M

BACKEND_CPU_LIMIT=2.00
BACKEND_MEMORY_RESERVATION=1024M
BACKEND_MEMORY_LIMIT=2048M
BACKEND_MEMORY_LIMIT_MB=2048

FRONTEND_CPU_LIMIT=1.00
FRONTEND_MEMORY_RESERVATION=256M
FRONTEND_MEMORY_LIMIT=512M

# Circuit breaker
C2F_CIRCUIT_BREAKER_ENABLED=true
C2F_CIRCUIT_BREAKER_THRESHOLD_PERCENT=90
C2F_CIRCUIT_BREAKER_POLL_SECONDS=2
C2F_CIRCUIT_BREAKER_MAX_PAUSE_SECONDS=120

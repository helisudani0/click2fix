# Core backend settings
DATABASE_URL=postgresql+psycopg2://click2fix:click2fix@db:5432/click2fix
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_32_PLUS_CHARS
JWT_ALGO=HS256
TOKEN_EXP_HOURS=8
C2F_ORCHESTRATION_MODE=endpoint

# Wazuh manager API credentials
WAZUH_URL=https://WAZUH_MANAGER_IP:55000
WAZUH_USER=c2f_api
WAZUH_PASSWORD=REPLACE_WITH_WAZUH_PASSWORD

# Wazuh indexer credentials
INDEXER_URL=https://WAZUH_INDEXER_IP:9200
INDEXER_USER=admin
INDEXER_PASSWORD=REPLACE_WITH_INDEXER_PASSWORD
OTX_API_KEY=

# Optional runtime settings
REDIS_URL=redis://localhost:6379/0
C2F_FORENSICS_PATH=./data/forensics

# Endpoint connector credentials
C2F_WINRM_USERNAME=
C2F_WINRM_PASSWORD=
C2F_WINRM_USERNAME_001=
C2F_WINRM_PASSWORD_001=
C2F_WINRM_USERNAME_004=
C2F_WINRM_PASSWORD_004=
C2F_SSH_USERNAME=
C2F_SSH_PASSWORD=

C2F_WINDOWS_CONNECTOR_ENABLED=true
C2F_LINUX_CONNECTOR_ENABLED=false
